pipeline {
    agent any
    environment {
        OWNER = 'cursus-studio'
        CONTEXT = 'jenkins/ci-cd'
        REPO = 'texhec'
        GITHUB_TOKEN = credentials('texhec-app')
    }

    stages {
        stage('Loading') {
            steps {
                updateGitHubStatus('pending', 'Build is in progress...')
            }
        }
    // stage('Sync Repo') {
    //     steps {
    //         checkout scm
    //     }
    // }
    }
    post {
        //  always {
        //          echo 'Cleanup'
        //  }
        success {
            // updateGitHubStatus('success', 'Pipeline passed!')
            updateGitHubStatus('success', 'Pipeline passed!')
        }
        failure {
            // updateGitHubStatus('failure', 'Pipeline failed!')
            updateGitHubStatus('failure', 'Pipeline failed!')
        }
    }
}

def updateGitHubStatus(String state, String description) {
    sh """
        curl -L -X POST \
        -H "Accept: application/vnd.github+json" \
        -H "Authorization: Bearer ${GITHUB_TOKEN}" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        https://api.github.com/repos/${OWNER}/${REPO}/statuses/${GIT_COMMIT} \
        -d "{\\"state\\":\\"${state}\\",\\"target_url\\":\\"${BUILD_URL}\\",\\"description\\":\\"${description}\\",\\"context\\":\\"${CONTEXT}\\"}"
    """
}
