pipeline {
    agent any
    environment {
        CONTEXT = 'jenkins/ci-cd'

        OWNER = 'cursus-studio'
        REPO = 'texhec'
    }

    stages {
        stage('Initialize') {
            steps {
                withCredentials([gitHubApp(credentialsId: 'texhec-app', variable: 'TEMP_TOKEN')]) {
                        GITHUB_TOKEN = TEMP_TOKEN
                }
                updateGitHubStatus('pending', 'Build is in progress...')
            }
        }
    // stage('Sync Repo') {
    //     steps {
    //         checkout scm
    //     }
    // }
    }
    post {
        //  always {
        //          echo 'Cleanup'
        //  }
        success {
            // updateGitHubStatus('success', 'Pipeline passed!')
            updateGitHubStatus('success', 'Pipeline passed!')
        }
        failure {
            // updateGitHubStatus('failure', 'Pipeline failed!')
            updateGitHubStatus('failure', 'Pipeline failed!')
        }
    }
}

def updateGitHubStatus(String state, String description) {
    withCredentials([gitHubApp(credentialsId: 'texhec-app', variable: 'GITHUB_TOKEN')]) {
        withEnv([
        "TOKEN=${env.GITHUB_TOKEN}",
        "URL=https://api.github.com/repos/${OWNER}/${REPO}/statuses/${env.GIT_COMMIT}",

        "STATE=${state}",
        "TARGET_URL=${env.BUILD_URL}",
        "DESCRIPTION=${description}",
        'CONTEXT=jenkins/ci-cd',
    ]) {
            sh 'bash ci-cd/set_status.sh'
    }
    }
}
