pipeline {
    agent any
    environment {
        CONTEXT = 'jenkins/ci-cd'
            OWNER = 'cursus-studio'
            REPO = 'texhec'
            TOKEN = credentials('759bb157-db18-4616-a402-324204b7027a')
            SHA = sh(script: 'git rev-parse HEAD', returnStdout: true).trim()
    }

    stages {
        stage('Loading') {
            steps {
                sh "echo Current SHA is ${SHA}"

                updateGitHubStatus('pending', 'Build is in progress...')
            }
        }
        stage('Sync Repo') {
            steps {
                checkout scm
            }
        }
        stage('Logging') {
            steps {
                echo "Current branch is: ${env.GIT_BRANCH}"
                echo 'Succesfully started pipeline'
            }
        }
    }
    post {
        //
        //  always {
        //          echo 'Cleanup'
        //  }
        success {
            updateGitHubStatus('success', 'Pipeline passed!')
        }
        failure {
            updateGitHubStatus('failure', 'Pipeline failed!')
        }
    }
}

def updateGitHubStatus(String state, String description) {
    sh """
        curl -L -X POST \
        -H "Accept: application/vnd.github+json" \
        -H "Authorization: Bearer ${TOKEN}" \
        -H "X-GitHub-Api-Version: 2022-11-28" \
        https://api.github.com/repos/${OWNER}/${REPO}/statuses/${env.GIT_COMMIT} \
        -d '{"state":"${state}","description":"${description}","context":"${CONTEXT}","target_url":"${env.BUILD_URL}"}'
    """
}
