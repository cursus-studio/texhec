pipeline {
    agent any
    environment {
        CONTEXT = 'jenkins/ci-cd'

        OWNER = 'cursus-studio'
        REPO = 'texhec'
    }

    stages {
        stage('Initialize') {
            steps {
                updateGitHubStatus('pending', 'Build is in progress...')
            }
        }
    // stage('Sync Repo') {
    //     steps {
    //         checkout scm
    //     }
    // }
    }
    post {
        //  always {
        //          echo 'Cleanup'
        //  }
        success {
            updateGitHubStatus('success', 'Pipeline passed!')
        }
        failure {
            updateGitHubStatus('failure', 'Pipeline failed!')
        }
    }
}

def updateGitHubStatus(String STATE, String DESC) {
    withCredentials([usernamePassword(credentialsId: 'texhec-app', passwordVariable: 'TOKEN', usernameVariable: 'USER')]) {
        withEnv([
            "GIT_COMMIT=${env.GIT_COMMIT}",
            "TARGET_URL=${env.BUILD_URL}",
            "STATE=${STATE}",
            "DESC=${DESC}",
        ]) {
            sh 'bash ci-cd/set_status.sh'
        }
    }
}
